{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "启动 Streamlit 工具",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\streamlit.exe",
      "args": [
        "run",
        "app.py",
        "--server.address",
        "127.0.0.1",
        "--server.port",
        "8501"
      ],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
